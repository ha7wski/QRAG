# ── LLM ─────────────────────────────────────────────────────
LLM_PROVIDER=ollama                 # "ollama" | "anthropic"
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b             # default; 72b needs a large GPU/RAM
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Vector DB (Qdrant) ──────────────────────────────────────
# When running locally outside Docker, use http://localhost:6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=quran_verses

# ── Embedding ───────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct
# Lightweight fallback (768 dims) if RAM is insufficient:
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=auto               # "auto" | "cpu" | "cuda" | "mps"
EMBEDDING_BATCH_SIZE=32

# ── Retrieval quality (Step 8 / phase 2) ────────────────────
# QueryProcessor: language/filters/Arabic-root expansion of the retrieval
# query. Cheap and deterministic (no LLM) — on by default.
QUERY_PROCESSOR_ENABLED=1
# HyDE: generate a hypothetical verse to enrich the retrieval query. Adds one
# LLM call per question (latency) — off by default.
HYDE_ENABLED=0
# Multilingual cross-encoder reranking (ar/fr/en). ~2.3 GB; off by default.
RERANK_ENABLED=0
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ── App ─────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
